# PayPerPrompt - Environment Variables Configuration Template
# Duplicate this file to .env.local and fill in the secrets for local development

# Kite Chain Testnet Configurations
NEXT_PUBLIC_KITE_RPC=https://rpc-testnet.gokite.ai
NEXT_PUBLIC_CHAIN_ID=2368
NEXT_PUBLIC_EXPLORER=https://testnet.kitescan.ai
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Gasless Relayer Endpoint
GASLESS_ENDPOINT=https://gasless.gokite.ai/testnet

# Kite Service Registry Contract Address
REGISTRY_CONTRACT_ADDRESS=0x4a9B3AFCbdCb38420fE4cADb9Cf0257c282fe173
NEXT_PUBLIC_REGISTRY_ADDRESS=0x4a9B3AFCbdCb38420fE4cADb9Cf0257c282fe173

# AI Agent Configuration Secrets (Keep private - never commit!)
OPENAI_API_KEY=your_openai_api_key_here
AGENT_PRIVATE_KEY=your_agent_private_key_hex
PRIVATE_KEY=your_owner_private_key_hex
